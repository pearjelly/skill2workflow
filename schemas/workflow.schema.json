{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill2workflow.dev/schemas/workflow-0.1.0.json",
  "title": "skill2workflow Workflow DSL",
  "description": "Workflow DSL document used as the execution truth source for skill2workflow.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "workflow", "entry", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "const": "0.1.0",
      "description": "Workflow DSL schema version."
    },
    "workflow": {
      "$ref": "#/$defs/workflow_metadata"
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "description": "Node id where execution starts."
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      },
      "minItems": 1
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "state_schema": {
      "type": "object",
      "description": "Optional workflow state schema for future typed execution state."
    },
    "guards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/guard"
      },
      "default": []
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "policies": {
      "$ref": "#/$defs/policies"
    }
  },
  "$defs": {
    "workflow_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "version", "status"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "published", "deprecated"]
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "title"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["start", "step", "human_gate", "tool_call", "verification", "instruction", "failure", "end"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "guard": {
          "type": ["object", "string", "null"]
        },
        "action": {
          "type": ["object", "null"]
        },
        "retry": {
          "type": ["object", "null"]
        },
        "metadata": {
          "type": "object"
        },
        "on_success": {
          "type": "string"
        },
        "on_failure": {
          "type": "string"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "from", "to"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": ["string", "null"]
        },
        "condition": {
          "type": ["object", "string", "null"]
        }
      }
    },
    "guard": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "default_retry": {
          "type": "object"
        },
        "default_timeout_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
